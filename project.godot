[layer_names]

3d_physics/layer_1="World"
3d_physics/layer_2="Player"
3d_physics/layer_3="Enemy"
3d_physics/layer_4="Pickup"
3d_physics/layer_5="PlayerHitbox"
3d_physics/layer_6="PlayerHurtbox"
3d_physics/layer_7="EnemyHitbox"
3d_physics/layer_8="EnemyHurtbox"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/vsync/swapchain_image_count=2
rendering_device/driver.windows="d3d12"
lights_and_shadows/directional_shadow/size=2048
lights_and_shadows/directional_shadow/soft_shadow_filter_quality=0
lights_and_shadows/positional_shadow/soft_shadow_filter_quality=0
occlusion_culling/use_occlusion_culling=true
lights_and_shadows/positional_shadow/atlas_size=2048
